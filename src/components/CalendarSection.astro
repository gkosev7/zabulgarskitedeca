---
import { getCollection } from 'astro:content';

function toDayKey(date: Date) {
	const year = date.getFullYear();
	const month = String(date.getMonth() + 1).padStart(2, '0');
	const day = String(date.getDate()).padStart(2, '0');
	return `${year}-${month}-${day}`;
}

const today = new Date();
today.setHours(0, 0, 0, 0);

const endDate = new Date(today);
endDate.setDate(endDate.getDate() + 30);

const allCalendarItems = await getCollection('calendar');
const calendarItems = allCalendarItems
	.filter((item) => {
		const itemDate = new Date(item.data.date);
		itemDate.setHours(0, 0, 0, 0);
		return itemDate >= today && itemDate <= endDate;
	})
	.sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf());

const calendarByDay = new Map<string, typeof calendarItems>();
for (const item of calendarItems) {
	const key = toDayKey(item.data.date);
	const bucket = calendarByDay.get(key) ?? [];
	bucket.push(item);
	calendarByDay.set(key, bucket);
}

const dayFullLabelFormatter = new Intl.DateTimeFormat('bg-BG', {
	weekday: 'long',
	day: 'numeric',
	month: 'long',
});
const dayWeekFormatter = new Intl.DateTimeFormat('bg-BG', {
	weekday: 'short',
});
const monthFormatter = new Intl.DateTimeFormat('bg-BG', {
	month: 'short',
});
const dayWeekFormatterEn = new Intl.DateTimeFormat('en-US', {
	weekday: 'short',
});
const monthFormatterEn = new Intl.DateTimeFormat('en-US', {
	month: 'short',
});

const weekdayHeaders = [
	{ bg: 'Пон', en: 'Mon' },
	{ bg: 'Вто', en: 'Tue' },
	{ bg: 'Сря', en: 'Wed' },
	{ bg: 'Чет', en: 'Thu' },
	{ bg: 'Пет', en: 'Fri' },
	{ bg: 'Съб', en: 'Sat' },
	{ bg: 'Нед', en: 'Sun' },
];

const firstGridDay = new Date(today);
const mondayOffset = (today.getDay() + 6) % 7;
firstGridDay.setDate(today.getDate() - mondayOffset);

const lastRangeDay = new Date(endDate);
const sundayOffset = (7 - ((lastRangeDay.getDay() + 6) % 7) - 1 + 7) % 7;
const lastGridDay = new Date(lastRangeDay);
lastGridDay.setDate(lastRangeDay.getDate() + sundayOffset);

const calendarCells = [];
for (let cursor = new Date(firstGridDay); cursor <= lastGridDay; cursor.setDate(cursor.getDate() + 1)) {
	const day = new Date(cursor);
	const key = toDayKey(day);
	calendarCells.push({
		key,
		fullLabel: dayFullLabelFormatter.format(day),
		dayNumber: day.getDate(),
		weekLabelBg: dayWeekFormatter.format(day).replace('.', ''),
		weekLabelEn: dayWeekFormatterEn.format(day).replace('.', ''),
		monthLabelBg: monthFormatter.format(day).replace('.', ''),
		monthLabelEn: monthFormatterEn.format(day).replace('.', ''),
		isToday: key === toDayKey(today),
		isCurrentRange: day >= today && day <= endDate,
		items: calendarByDay.get(key) ?? [],
	});
}
---

<section class="calendar-wrap">
	<h2 class="calendar-title">
		<span data-i18n-bg="Календар: Следващи 31 Дни" data-i18n-en="Calendar: Next 31 Days">
			Календар: Следващи 31 Дни
		</span>
	</h2>
	<p class="calendar-subtitle">
		<span
			data-i18n-bg="Показва всички събития от днес нататък за 31 дни напред."
			data-i18n-en="Shows all events from today through the next 31 days."
		>
			Показва всички събития от днес нататък за 31 дни напред.
		</span>
	</p>
	<div class="weekday-row" aria-hidden="true">
		{
			weekdayHeaders.map((day) => (
				<div class="weekday-cell">
					<span data-i18n-bg={day.bg} data-i18n-en={day.en}>{day.bg}</span>
				</div>
			))
		}
	</div>
	<ul class="calendar-grid">
		{
			calendarCells.map((day) => (
				<li class:list={['day-card', { today: day.isToday, 'outside-range': !day.isCurrentRange }]}>
					<h3 class="day-heading" title={day.fullLabel}>
						<span class="day-num">{day.dayNumber}</span>
						<span data-i18n-bg={day.weekLabelBg} data-i18n-en={day.weekLabelEn}>{day.weekLabelBg}</span>
						<span data-i18n-bg={day.monthLabelBg} data-i18n-en={day.monthLabelEn}>{day.monthLabelBg}</span>
					</h3>
					{day.items.length === 0 ? (
						<p class="no-events" data-i18n-bg="Няма събития" data-i18n-en="No events">
							Няма събития
						</p>
					) : (
						<ul class="event-list">
							{day.items.slice(0, 2).map((item) => (
								<li class="event-item">
									<p class="event-title">{item.data.title}</p>
									{(item.data.time || item.data.location) && (
										<p class="event-meta">
											{item.data.time && <span>{item.data.time}</span>}
											{item.data.time && item.data.location && <span> · </span>}
											{item.data.location && <span>{item.data.location}</span>}
										</p>
									)}
								</li>
							))}
							{day.items.length > 2 && (
								<li
									class="more-events"
									data-i18n-template-bg="+{n} още"
									data-i18n-template-en="+{n} more"
									data-i18n-count={String(day.items.length - 2)}
								>
									+{day.items.length - 2} още
								</li>
							)}
						</ul>
					)}
				</li>
			))
		}
	</ul>
</section>

<style>
	.calendar-wrap {
		margin-top: 2rem;
		padding: 1rem;
		border-radius: 16px;
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.76), rgba(255, 255, 255, 0.26) 65%),
			linear-gradient(150deg, #f7fcff, #e6f5ff 50%, #e8f8f1);
		box-shadow: 0 8px 20px rgba(78, 126, 170, 0.15);
		border: 1px solid rgba(130, 192, 223, 0.35);
	}
	.calendar-title {
		margin: 0 0 0.4rem 0;
		font-size: 2rem;
	}
	.calendar-subtitle {
		margin: 0 0 0.8rem 0;
		color: rgb(var(--gray-dark));
	}
	.weekday-row,
	.calendar-grid {
		display: grid;
		grid-template-columns: repeat(7, minmax(0, 1fr));
		gap: 0.45rem;
	}
	.weekday-row {
		margin: 0 0 0.45rem 0;
	}
	.weekday-cell {
		padding: 0.32rem 0.18rem;
		text-align: center;
		font-size: 0.76rem;
		font-weight: 700;
		letter-spacing: 0.03em;
		text-transform: uppercase;
		color: rgb(var(--gray-dark));
	}
	.calendar-grid {
		padding: 0;
		margin: 0;
		list-style: none;
	}
	.day-card {
		border-radius: 10px;
		padding: 0.5rem;
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.9), rgba(239, 248, 255, 0.86)),
			#ffffff;
		border: 1px solid rgba(var(--gray), 0.25);
		min-height: 7.6rem;
		display: grid;
		grid-template-rows: auto 1fr;
		gap: 0.35rem;
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.75);
	}
	.day-card.outside-range {
		opacity: 0.58;
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.78), rgba(238, 241, 245, 0.84)),
			#ffffff;
	}
	.day-card.today {
		border-color: #00966e;
		box-shadow: inset 0 0 0 1px rgba(0, 150, 110, 0.28);
	}
	.day-heading {
		margin: 0;
		display: flex;
		align-items: center;
		gap: 0.28rem;
		font-size: 0.8rem;
		line-height: 1;
		color: rgb(var(--gray-dark));
	}
	.day-num {
		font-size: 1.25rem;
		font-weight: 700;
		color: rgb(var(--black));
	}
	.event-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		gap: 0.25rem;
		align-content: start;
	}
	.event-item {
		padding: 0.28rem 0.35rem;
		border-radius: 6px;
		background: linear-gradient(180deg, rgba(255, 255, 255, 0.75), rgba(216, 240, 251, 0.52));
	}
	.event-title {
		margin: 0;
		font-size: 0.8rem;
		font-weight: 700;
		line-height: 1.2;
	}
	.event-meta {
		margin: 0.12rem 0 0 0;
		font-size: 0.72rem;
		color: rgb(var(--gray-dark));
	}
	.more-events {
		margin: 0.12rem 0 0 0;
		font-size: 0.72rem;
		font-weight: 700;
		color: #00966e;
	}
	.no-events {
		margin: 0;
		font-size: 0.76rem;
		color: rgb(var(--gray));
	}
	@media (max-width: 900px) {
		.weekday-cell {
			font-size: 0.68rem;
		}
	}
	@media (max-width: 700px) {
		.day-card {
			min-height: 5.1rem;
			padding: 0.28rem;
		}
		.weekday-cell {
			font-size: 0.58rem;
			padding: 0.22rem 0.08rem;
		}
		.day-heading {
			font-size: 0.56rem;
			gap: 0.16rem;
		}
		.day-num {
			font-size: 0.82rem;
		}
		.event-title {
			font-size: 0.54rem;
			line-height: 1.1;
		}
		.event-meta,
		.more-events,
		.no-events {
			font-size: 0.48rem;
		}
	}
	@media (max-width: 480px) {
		.weekday-row,
		.calendar-grid {
			gap: 0.35rem;
		}
		.weekday-cell {
			font-size: 0.5rem;
			letter-spacing: 0.01em;
		}
		.day-card {
			min-height: 4.55rem;
			padding: 0.2rem;
		}
		.day-heading {
			font-size: 0.46rem;
			gap: 0.12rem;
		}
		.day-num {
			font-size: 0.7rem;
		}
		.event-title {
			font-size: 0.48rem;
		}
		.event-meta,
		.more-events,
		.no-events {
			font-size: 0.42rem;
		}
	}
</style>
