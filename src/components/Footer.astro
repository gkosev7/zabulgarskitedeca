---
const today = new Date();
---

<footer>
	<p class="footer-copy">
		<a href="/contacts"><span data-i18n-bg="Контакти" data-i18n-en="Contacts">Контакти</span></a>
		<span aria-hidden="true"> · </span>
		&copy; {today.getFullYear()} <span data-i18n-bg="Всички права запазени." data-i18n-en="All rights reserved.">Всички права запазени.</span>
	</p>
</footer>
<style>
	@import url("https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@1,500;1,600&display=swap");

	footer {
		padding: 1.2em 1em 1.5em 1em;
		margin-top: auto;
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.2), transparent 52%),
			linear-gradient(145deg, #676d77, #575d67 58%, #4d535d);
		color: #f2f4f7;
		text-align: center;
		font-family: "Cormorant Garamond", serif;
		font-style: italic;
		border-top: 1px solid rgba(255, 255, 255, 0.18);
	}
	.footer-copy {
		margin: 0;
		font-size: 1.02rem;
		color: rgba(255, 255, 255, 0.86);
		font-family: inherit;
		font-style: inherit;
	}
	.footer-copy a {
		color: #ffffff;
		text-decoration: none;
	}
	.footer-copy a:hover {
		text-decoration: underline;
	}
	@media (max-width: 720px) {
		footer {
			padding: 1.1em 0.8em 1.4em 0.8em;
		}
		.footer-copy {
			font-size: 0.92rem;
		}
	}
</style>
