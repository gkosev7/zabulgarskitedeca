---
const today = new Date();
---

<footer>
	<section class="footer-info" aria-label="Контактна информация">
		<p class="footer-line">
			<svg viewBox="0 0 24 24" aria-hidden="true">
				<path d="M12 12a5 5 0 1 0-5-5 5 5 0 0 0 5 5zm0 2c-4.42 0-8 2.24-8 5v1h16v-1c0-2.76-3.58-5-8-5z"></path>
			</svg>
			<span>Асинка Стефанова Стефанова</span>
		</p>
		<p class="footer-line">
			<svg viewBox="0 0 24 24" aria-hidden="true">
				<path d="M4 5h16a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2zm0 2v.01L12 13l8-5.99V7z"></path>
			</svg>
			<a href="mailto:forbgchildren@gmail.com">forbgchildren@gmail.com</a>
		</p>
		<p class="footer-line">
			<svg viewBox="0 0 24 24" aria-hidden="true">
				<path d="M12 2a7 7 0 0 0-7 7c0 5.25 7 13 7 13s7-7.75 7-13a7 7 0 0 0-7-7zm0 10a3 3 0 1 1 3-3 3 3 0 0 1-3 3z"></path>
			</svg>
			<span>Владайска 75 София</span>
		</p>
		<p class="footer-line">
			<svg viewBox="0 0 24 24" aria-hidden="true">
				<path d="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1-.24 11.3 11.3 0 0 0 3.55.57 1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A17 17 0 0 1 3 4a1 1 0 0 1 1-1h3.49a1 1 0 0 1 1 1 11.3 11.3 0 0 0 .57 3.55 1 1 0 0 1-.24 1z"></path>
			</svg>
			<a href="tel:+359887723420">+359887723420</a>
		</p>
	</section>
	<p class="footer-copy">&copy; {today.getFullYear()} Всички права запазени.</p>
</footer>
<style>
	@import url("https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@1,500;1,600&display=swap");

	footer {
		padding: 1.8em 1em 2.4em 1em;
		margin-top: auto;
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.2), transparent 52%),
			linear-gradient(145deg, #676d77, #575d67 58%, #4d535d);
		color: #f2f4f7;
		text-align: center;
		font-family: "Cormorant Garamond", serif;
		font-style: italic;
		border-top: 1px solid rgba(255, 255, 255, 0.18);
	}
	.footer-info {
		display: inline-grid;
		gap: 0.45rem;
		margin: 0 auto 1rem auto;
		text-align: left;
	}
	.footer-line {
		margin: 0;
		display: flex;
		align-items: center;
		gap: 0.35rem;
		font-family: "Cormorant Garamond", serif;
		font-style: italic;
		font-size: 1.06rem;
		letter-spacing: 0.01em;
	}
	.footer-line svg {
		width: 0.78rem;
		height: 0.78rem;
		fill: #ffffff;
		flex-shrink: 0;
	}
	.footer-line a {
		color: #ffffff;
		text-decoration: none;
	}
	.footer-line a:hover {
		text-decoration: underline;
	}
	.footer-copy {
		margin: 0;
		font-size: 1.02rem;
		color: rgba(255, 255, 255, 0.86);
		font-family: inherit;
		font-style: inherit;
	}
	@media (max-width: 720px) {
		footer {
			padding: 1.45em 0.8em 2em 0.8em;
		}
		.footer-info {
			width: min(100%, 26rem);
			text-align: center;
			gap: 0.35rem;
		}
		.footer-line {
			justify-content: center;
			font-size: 0.98rem;
			gap: 0.3rem;
		}
		.footer-line svg {
			width: 0.68rem;
			height: 0.68rem;
		}
		.footer-copy {
			font-size: 0.92rem;
		}
	}
</style>
