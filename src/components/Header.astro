---
import HeaderLink from './HeaderLink.astro';
import LanguageToggle from './LanguageToggle.astro';
---

<header>
	<nav>
		<h2 class="brand-title">
			<a href="/" aria-label="За Българските Деца">
				<img
					class="brand-logo"
					src="/logo.png"
					alt=""
					aria-hidden="true"
					decoding="async"
					loading="lazy"
					onerror="this.style.display='none'"
				/>
				<span class="brand-white">За</span>
				<span class="brand-green">Българските</span>
				<span class="brand-red">Деца</span>
			</a>
		</h2>
		<div class="internal-links">
			<HeaderLink href="/"><span data-i18n-bg="Начало" data-i18n-en="Home">Начало</span></HeaderLink>
			<HeaderLink href="/calendar"><span data-i18n-bg="Календар" data-i18n-en="Calendar">Календар</span></HeaderLink>
			<HeaderLink href="/blog"><span data-i18n-bg="Блог" data-i18n-en="Blog">Блог</span></HeaderLink>
			<HeaderLink href="/about"><span data-i18n-bg="За нас" data-i18n-en="About us">За нас</span></HeaderLink>
			<HeaderLink href="/donations"><span data-i18n-bg="Дарения" data-i18n-en="Donations">Дарения</span></HeaderLink>
			<HeaderLink href="/contacts"><span data-i18n-bg="Контакти" data-i18n-en="Contacts">Контакти</span></HeaderLink>
			<LanguageToggle />
		</div>
	</nav>
</header>
<style>
	@import url("https://fonts.googleapis.com/css2?family=Marck+Script&display=swap");

	header {
		margin: 0;
		padding: 0 1em;
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.2), transparent 58%),
			linear-gradient(145deg, #5f6670, #49505a 62%, #434a54);
		box-shadow: 0 2px 8px rgba(var(--black), 12%);
		border-bottom: 1px solid rgba(255, 255, 255, 0.2);
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}
	.brand-title {
		font-size: 1.85rem;
		line-height: 1.1;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	.brand-title a,
	.brand-title a.active {
		font-family: "Marck Script", cursive;
		font-weight: 400;
		letter-spacing: 0.03em;
		display: inline-flex;
		gap: 0.28em;
		align-items: center;
	}
	.brand-title a span {
		line-height: 1;
	}
	.brand-logo {
		width: 3rem;
		height: 3rem;
		object-fit: contain;
		flex-shrink: 0;
		transform: scale(1.22);
		transform-origin: center;
	}
	.brand-white {
		color: #ffffff;
		text-shadow: 0 1px 1px rgba(var(--black), 0.85), 0 2px 4px rgba(var(--black), 0.55);
	}
	.brand-green {
		color: #00966e;
		text-shadow: 0 1px 1px rgba(var(--black), 0.6), 0 2px 4px rgba(var(--black), 0.4);
	}
	.brand-red {
		color: #d62612;
		text-shadow: 0 1px 1px rgba(var(--black), 0.6), 0 2px 4px rgba(var(--black), 0.4);
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}
	.internal-links {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: flex-end;
	}
	.internal-links a {
		font-family: "Marck Script", cursive;
		font-size: 1.35rem;
		padding: 1em 0.5em;
		color: #f8f9fa;
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	.internal-links a.active {
		text-decoration: none;
		border-bottom: 4px solid;
		border-image: linear-gradient(90deg, #ffffff 0 33.333%, #00966e 33.333% 66.666%, #d62612 66.666% 100%) 1;
	}
	@media (max-width: 900px) {
		.brand-title {
			font-size: 1.5rem;
		}
		.brand-logo {
			width: 2.35rem;
			height: 2.35rem;
		}
		.internal-links a {
			font-size: 1.15rem;
			padding: 0.85em 0.45em;
		}
	}
	@media (max-width: 700px) {
		header {
			padding: 0.35em 0.7em;
		}
		nav {
			flex-direction: column;
			align-items: stretch;
			gap: 0.15rem;
		}
		.brand-title {
			font-size: 1.35rem;
			text-align: center;
		}
		.brand-logo {
			width: 2rem;
			height: 2rem;
		}
		.brand-title a,
		.brand-title a.active {
			justify-content: center;
		}
		.internal-links {
			justify-content: center;
			row-gap: 0.1rem;
		}
		.internal-links a {
			font-size: 1.1rem;
			padding: 0.55em 0.42em;
			border-bottom-width: 3px;
		}
	}
</style>
