---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

function toDayKey(date: Date) {
	const year = date.getFullYear();
	const month = String(date.getMonth() + 1).padStart(2, '0');
	const day = String(date.getDate()).padStart(2, '0');
	return `${year}-${month}-${day}`;
}

const today = new Date();
today.setHours(0, 0, 0, 0);

const endDate = new Date(today);
endDate.setDate(endDate.getDate() + 30);

const allCalendarItems = await getCollection('calendar');
const calendarItems = allCalendarItems
	.filter((item) => {
		const itemDate = new Date(item.data.date);
		itemDate.setHours(0, 0, 0, 0);
		return itemDate >= today && itemDate <= endDate;
	})
	.sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf());

const calendarByDay = new Map<string, typeof calendarItems>();
for (const item of calendarItems) {
	const key = toDayKey(item.data.date);
	const bucket = calendarByDay.get(key) ?? [];
	bucket.push(item);
	calendarByDay.set(key, bucket);
}

const dayFullLabelFormatter = new Intl.DateTimeFormat('bg-BG', {
	weekday: 'long',
	day: 'numeric',
	month: 'long',
});
const dayWeekFormatter = new Intl.DateTimeFormat('bg-BG', {
	weekday: 'short',
});
const monthFormatter = new Intl.DateTimeFormat('bg-BG', {
	month: 'short',
});
const dayWeekFormatterEn = new Intl.DateTimeFormat('en-US', {
	weekday: 'short',
});
const monthFormatterEn = new Intl.DateTimeFormat('en-US', {
	month: 'short',
});

const next31Days = Array.from({ length: 31 }, (_, index) => {
	const day = new Date(today);
	day.setDate(today.getDate() + index);
	return {
		key: toDayKey(day),
		fullLabel: dayFullLabelFormatter.format(day),
		dayNumber: day.getDate(),
		weekLabelBg: dayWeekFormatter.format(day).replace('.', ''),
		weekLabelEn: dayWeekFormatterEn.format(day).replace('.', ''),
		monthLabelBg: monthFormatter.format(day).replace('.', ''),
		monthLabelEn: monthFormatterEn.format(day).replace('.', ''),
		isToday: index === 0,
		items: calendarByDay.get(toDayKey(day)) ?? [],
	};
});
---

<!doctype html>
<html lang="bg">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: min(1100px, calc(100% - 2em));
			}
			.mission-wrap {
				margin-top: 0.75rem;
				padding: 1.55rem 1.75rem;
				border-radius: 14px;
				background:
					linear-gradient(180deg, rgba(255, 255, 255, 0.72), rgba(255, 255, 255, 0.2) 65%),
					linear-gradient(160deg, #fbfeff, #e9f6ff 58%, #ebfaf3);
				border: 1px solid rgba(var(--gray), 0.26);
				box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.75), 0 8px 18px rgba(88, 130, 166, 0.12);
			}
			.mission-layout {
				display: grid;
				grid-template-columns: minmax(0, 1.25fr) minmax(250px, 0.75fr);
				gap: 1.35rem;
				align-items: center;
			}
			.mission-logo {
				width: clamp(220px, 24vw, 320px);
				height: auto;
				object-fit: contain;
				justify-self: end;
				filter: drop-shadow(0 3px 8px rgba(44, 82, 120, 0.2));
			}
			.mission-title {
				margin: 0 0 0.5rem 0;
				font-size: 1.9rem;
			}
			.mission-lead {
				margin: 0 0 0.7rem 0;
			}
			.mission-points {
				margin: 0;
				padding-left: 1.15rem;
				display: grid;
				gap: 0.35rem;
			}
			.mission-cta {
				margin: 0.8rem 0 0 0;
				font-weight: 700;
			}
			.calendar-wrap {
				margin-top: 2rem;
				padding: 1rem;
				border-radius: 16px;
				background:
					linear-gradient(180deg, rgba(255, 255, 255, 0.76), rgba(255, 255, 255, 0.26) 65%),
					linear-gradient(150deg, #f7fcff, #e6f5ff 50%, #e8f8f1);
				box-shadow: 0 8px 20px rgba(78, 126, 170, 0.15);
				border: 1px solid rgba(130, 192, 223, 0.35);
			}
			.calendar-title {
				margin: 0 0 0.4rem 0;
				font-size: 2rem;
			}
			.calendar-subtitle {
				margin: 0 0 0.8rem 0;
				color: rgb(var(--gray-dark));
			}
			.calendar-grid {
				display: grid;
				grid-template-columns: repeat(7, minmax(0, 1fr));
				gap: 0.45rem;
				padding: 0;
				margin: 0;
				list-style: none;
			}
			.day-card {
				border-radius: 10px;
				padding: 0.5rem;
				background:
					linear-gradient(180deg, rgba(255, 255, 255, 0.9), rgba(239, 248, 255, 0.86)),
					#ffffff;
				border: 1px solid rgba(var(--gray), 0.25);
				min-height: 7.6rem;
				display: grid;
				grid-template-rows: auto 1fr;
				gap: 0.35rem;
				box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.75);
			}
			.day-card.today {
				border-color: #00966e;
				box-shadow: inset 0 0 0 1px rgba(0, 150, 110, 0.28);
			}
			.day-heading {
				margin: 0;
				display: flex;
				align-items: center;
				gap: 0.28rem;
				font-size: 0.8rem;
				line-height: 1;
				color: rgb(var(--gray-dark));
			}
			.day-num {
				font-size: 1.25rem;
				font-weight: 700;
				color: rgb(var(--black));
			}
			.event-list {
				list-style: none;
				padding: 0;
				margin: 0;
				display: grid;
				gap: 0.25rem;
				align-content: start;
			}
			.event-item {
				padding: 0.28rem 0.35rem;
				border-radius: 6px;
				background: linear-gradient(180deg, rgba(255, 255, 255, 0.75), rgba(216, 240, 251, 0.52));
			}
			.event-title {
				margin: 0;
				font-size: 0.8rem;
				font-weight: 700;
				line-height: 1.2;
			}
			.event-meta {
				margin: 0.12rem 0 0 0;
				font-size: 0.72rem;
				color: rgb(var(--gray-dark));
			}
			.more-events {
				margin: 0.12rem 0 0 0;
				font-size: 0.72rem;
				font-weight: 700;
				color: #00966e;
			}
			.no-events {
				margin: 0;
				font-size: 0.76rem;
				color: rgb(var(--gray));
			}
			@media (max-width: 1300px) {
				.calendar-grid {
					grid-template-columns: repeat(5, minmax(0, 1fr));
				}
			}
			@media (max-width: 900px) {
				.calendar-grid {
					grid-template-columns: repeat(3, minmax(0, 1fr));
				}
			}
			@media (max-width: 700px) {
				.mission-wrap {
					padding: 1.15rem 1rem;
				}
				.mission-layout {
					grid-template-columns: 1fr;
				}
				.mission-logo {
					width: min(65vw, 250px);
					justify-self: center;
				}
				.calendar-grid {
					display: flex;
					gap: 0.55rem;
					overflow-x: auto;
					padding-bottom: 0.35rem;
					scroll-snap-type: x mandatory;
				}
				.day-card {
					min-height: 6.4rem;
					min-width: 10.3rem;
					flex: 0 0 10.3rem;
					scroll-snap-align: start;
				}
			}
			@media (max-width: 480px) {
				.calendar-grid {
					display: flex;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="mission-wrap">
				<div class="mission-layout">
					<div>
						<h1 class="mission-title"><span data-i18n-bg="Нашата Мисия" data-i18n-en="Our Mission">Нашата Мисия</span></h1>
						<p class="mission-lead">
							<span
								data-i18n-bg="Изграждаме общност от информирани, активни и интелигентни младежи от цяла България, с фокус върху младите хора в малките населени места."
								data-i18n-en="We build a community of informed, active, and intelligent youth across Bulgaria, with a focus on young people in smaller towns and villages."
							>
								Изграждаме общност от информирани, активни и интелигентни младежи от цяла България, с фокус
								върху младите хора в малките населени места.
							</span>
						</p>
						<ul class="mission-points">
							<li><span data-i18n-bg="Кариерна и професионална ориентация чрез съвременни образователни методики." data-i18n-en="Career and professional orientation through modern educational methods.">Кариерна и професионална ориентация чрез съвременни образователни методики.</span></li>
							<li><span data-i18n-bg="Развитие на заложби в науки, изкуства и професии." data-i18n-en="Development of talent in sciences, arts, and professions.">Развитие на заложби в науки, изкуства и професии.</span></li>
							<li>
								<span
									data-i18n-bg="Практическо запознаване с теми като гражданско образование, икономика, политика, финансова грамотност, екология и медии."
									data-i18n-en="Practical introduction to civic education, economics, politics, financial literacy, ecology, and media."
								>
									Практическо запознаване с теми като гражданско образование, икономика, политика, финансова
									грамотност, екология и медии.
								</span>
							</li>
							<li><span data-i18n-bg="Подкрепа на местната култура, изкуства и традиции." data-i18n-en="Support for local culture, arts, and traditions.">Подкрепа на местната култура, изкуства и традиции.</span></li>
							<li><span data-i18n-bg="Личностно израстване, творческа изява и активна обществена комуникация." data-i18n-en="Personal growth, creative expression, and active social communication.">Личностно израстване, творческа изява и активна обществена комуникация.</span></li>
						</ul>
						<p class="mission-cta">
							<span data-i18n-bg="Пълният текст на целите можете да прочетете на страницата " data-i18n-en="You can read the full mission details on the page ">Пълният текст на целите можете да прочетете на страницата </span><a href="/about"><span data-i18n-bg="„За нас“" data-i18n-en="“About us”">„За нас“</span></a>.
						</p>
					</div>
					<img
						class="mission-logo"
						src="/logo.png"
						alt="Лого на Фондацията"
						decoding="async"
						loading="lazy"
						onerror="this.style.display='none'"
					/>
				</div>
			</section>
			<section class="calendar-wrap">
				<h2 class="calendar-title"><span data-i18n-bg="Календар: Следващи 31 Дни" data-i18n-en="Calendar: Next 31 Days">Календар: Следващи 31 Дни</span></h2>
				<p class="calendar-subtitle">
					<span data-i18n-bg="Показва всички събития от днес нататък за 31 дни напред." data-i18n-en="Shows all events from today through the next 31 days.">Показва всички събития от днес нататък за 31 дни напред.</span>
				</p>
				<ul class="calendar-grid">
					{
						next31Days.map((day) => (
							<li class={`day-card ${day.isToday ? 'today' : ''}`}>
								<h3 class="day-heading" title={day.fullLabel}>
									<span class="day-num">{day.dayNumber}</span>
									<span data-i18n-bg={day.weekLabelBg} data-i18n-en={day.weekLabelEn}>
										{day.weekLabelBg}
									</span>
									<span data-i18n-bg={day.monthLabelBg} data-i18n-en={day.monthLabelEn}>
										{day.monthLabelBg}
									</span>
								</h3>
								{day.items.length === 0 ? (
									<p class="no-events" data-i18n-bg="Няма събития" data-i18n-en="No events">Няма събития</p>
								) : (
									<ul class="event-list">
										{day.items.slice(0, 2).map((item) => (
											<li class="event-item">
												<p class="event-title">{item.data.title}</p>
												{(item.data.time || item.data.location) && (
													<p class="event-meta">
														{item.data.time && <span>{item.data.time}</span>}
														{item.data.time && item.data.location && <span> · </span>}
														{item.data.location && <span>{item.data.location}</span>}
													</p>
												)}
											</li>
										))}
										{day.items.length > 2 && (
											<li
												class="more-events"
												data-i18n-template-bg="+{n} още"
												data-i18n-template-en="+{n} more"
												data-i18n-count={String(day.items.length - 2)}
											>
												+{day.items.length - 2} още
											</li>
										)}
									</ul>
								)}
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
