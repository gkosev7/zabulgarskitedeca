---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

function toDayKey(date: Date) {
	const year = date.getFullYear();
	const month = String(date.getMonth() + 1).padStart(2, '0');
	const day = String(date.getDate()).padStart(2, '0');
	return `${year}-${month}-${day}`;
}

const today = new Date();
today.setHours(0, 0, 0, 0);

const endDate = new Date(today);
endDate.setDate(endDate.getDate() + 30);

const allCalendarItems = await getCollection('calendar');
const calendarItems = allCalendarItems
	.filter((item) => {
		const itemDate = new Date(item.data.date);
		itemDate.setHours(0, 0, 0, 0);
		return itemDate >= today && itemDate <= endDate;
	})
	.sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf());

const calendarByDay = new Map<string, typeof calendarItems>();
for (const item of calendarItems) {
	const key = toDayKey(item.data.date);
	const bucket = calendarByDay.get(key) ?? [];
	bucket.push(item);
	calendarByDay.set(key, bucket);
}

const dayFullLabelFormatter = new Intl.DateTimeFormat('bg-BG', {
	weekday: 'long',
	day: 'numeric',
	month: 'long',
});
const dayWeekFormatter = new Intl.DateTimeFormat('bg-BG', {
	weekday: 'short',
});
const monthFormatter = new Intl.DateTimeFormat('bg-BG', {
	month: 'short',
});
const dayWeekFormatterEn = new Intl.DateTimeFormat('en-US', {
	weekday: 'short',
});
const monthFormatterEn = new Intl.DateTimeFormat('en-US', {
	month: 'short',
});

const next31Days = Array.from({ length: 31 }, (_, index) => {
	const day = new Date(today);
	day.setDate(today.getDate() + index);
	return {
		key: toDayKey(day),
		fullLabel: dayFullLabelFormatter.format(day),
		dayNumber: day.getDate(),
		weekLabelBg: dayWeekFormatter.format(day).replace('.', ''),
		weekLabelEn: dayWeekFormatterEn.format(day).replace('.', ''),
		monthLabelBg: monthFormatter.format(day).replace('.', ''),
		monthLabelEn: monthFormatterEn.format(day).replace('.', ''),
		isToday: index === 0,
		items: calendarByDay.get(toDayKey(day)) ?? [],
	};
});

const weekdayHeaders = [
	{ bg: 'Пон', en: 'Mon' },
	{ bg: 'Вто', en: 'Tue' },
	{ bg: 'Сря', en: 'Wed' },
	{ bg: 'Чет', en: 'Thu' },
	{ bg: 'Пет', en: 'Fri' },
	{ bg: 'Съб', en: 'Sat' },
	{ bg: 'Нед', en: 'Sun' },
];

const firstGridDay = new Date(today);
const mondayOffset = (today.getDay() + 6) % 7;
firstGridDay.setDate(today.getDate() - mondayOffset);

const lastRangeDay = new Date(endDate);
const sundayOffset = (7 - ((lastRangeDay.getDay() + 6) % 7) - 1 + 7) % 7;
const lastGridDay = new Date(lastRangeDay);
lastGridDay.setDate(lastRangeDay.getDate() + sundayOffset);

const calendarCells = [];
for (let cursor = new Date(firstGridDay); cursor <= lastGridDay; cursor.setDate(cursor.getDate() + 1)) {
	const day = new Date(cursor);
	const key = toDayKey(day);
	calendarCells.push({
		key,
		fullLabel: dayFullLabelFormatter.format(day),
		dayNumber: day.getDate(),
		weekLabelBg: dayWeekFormatter.format(day).replace('.', ''),
		weekLabelEn: dayWeekFormatterEn.format(day).replace('.', ''),
		monthLabelBg: monthFormatter.format(day).replace('.', ''),
		monthLabelEn: monthFormatterEn.format(day).replace('.', ''),
		isToday: key === toDayKey(today),
		isCurrentRange: day >= today && day <= endDate,
		items: calendarByDay.get(key) ?? [],
	});
}
---

<!doctype html>
<html lang="bg">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: min(1100px, calc(100% - 2em));
			}
			.mission-wrap {
				margin-top: 0.75rem;
				padding: 1.55rem 1.75rem;
				border-radius: 14px;
				background:
					linear-gradient(180deg, rgba(255, 255, 255, 0.72), rgba(255, 255, 255, 0.2) 65%),
					linear-gradient(160deg, #fbfeff, #e9f6ff 58%, #ebfaf3);
				border: 1px solid rgba(var(--gray), 0.26);
				box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.75), 0 8px 18px rgba(88, 130, 166, 0.12);
			}
			.mission-layout {
				display: grid;
				grid-template-columns: minmax(0, 1.25fr) minmax(250px, 0.75fr);
				gap: 1.35rem;
				align-items: center;
			}
			.mission-visual {
				position: relative;
				width: min(100%, 360px);
				aspect-ratio: 1 / 1.08;
				justify-self: end;
				border-radius: 26px;
				overflow: hidden;
				background:
					linear-gradient(180deg, rgba(255, 255, 255, 0.42), transparent 28%),
					linear-gradient(180deg, #bfe9ff 0%, #dff7ff 34%, #d6f1ec 58%, #79bfd7 78%, #4da3bf 100%);
				border: 1px solid rgba(118, 183, 214, 0.44);
				box-shadow:
					inset 0 1px 0 rgba(255, 255, 255, 0.8),
					0 12px 24px rgba(79, 132, 173, 0.16);
			}
			.mission-visual::before {
				content: "";
				position: absolute;
				inset: auto -10% -6% -10%;
				height: 28%;
				border-radius: 50% 50% 0 0;
				background: linear-gradient(180deg, rgba(114, 188, 212, 0.88), #2f8bb1);
			}
			.sun {
				position: absolute;
				top: 9%;
				right: 10%;
				width: 72px;
				height: 72px;
				border-radius: 50%;
				background: radial-gradient(circle at 35% 35%, #fff9cc 0%, #ffe27a 52%, #f8b940 100%);
				box-shadow: 0 0 32px rgba(255, 214, 107, 0.7);
			}
			.cloud {
				position: absolute;
				background: rgba(255, 255, 255, 0.8);
				border-radius: 999px;
				filter: blur(0.2px);
			}
			.cloud::before,
			.cloud::after {
				content: "";
				position: absolute;
				background: inherit;
				border-radius: inherit;
			}
			.cloud-one {
				top: 13%;
				left: 10%;
				width: 78px;
				height: 24px;
			}
			.cloud-one::before {
				width: 30px;
				height: 30px;
				left: 10px;
				top: -14px;
			}
			.cloud-one::after {
				width: 38px;
				height: 38px;
				right: 12px;
				top: -18px;
			}
			.cloud-two {
				top: 24%;
				right: 26%;
				width: 64px;
				height: 20px;
			}
			.cloud-two::before {
				width: 26px;
				height: 26px;
				left: 8px;
				top: -12px;
			}
			.cloud-two::after {
				width: 30px;
				height: 30px;
				right: 8px;
				top: -14px;
			}
			.bird {
				position: absolute;
				width: 18px;
				height: 10px;
				border-top: 2px solid rgba(72, 105, 135, 0.78);
				border-radius: 50% 50% 0 0;
				transform: rotate(-8deg);
			}
			.bird::after {
				content: "";
				position: absolute;
				left: 8px;
				top: -2px;
				width: 18px;
				height: 10px;
				border-top: 2px solid rgba(72, 105, 135, 0.78);
				border-radius: 50% 50% 0 0;
				transform: rotate(16deg);
			}
			.bird-one {
				top: 20%;
				left: 24%;
			}
			.bird-two {
				top: 29%;
				left: 58%;
				transform: scale(0.82) rotate(4deg);
			}
			.book {
				position: absolute;
				left: 50%;
				bottom: 26%;
				width: 150px;
				height: 84px;
				transform: translateX(-50%);
			}
			.book-left,
			.book-right {
				position: absolute;
				top: 0;
				width: 72px;
				height: 84px;
				background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), #f8fbff 72%, #d7e6f0);
				box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.92);
			}
			.book-left {
				left: 0;
				border-radius: 8px 0 18px 14px;
				transform: skewY(8deg);
			}
			.book-right {
				right: 0;
				border-radius: 0 8px 14px 18px;
				transform: skewY(-8deg);
			}
			.book-spine {
				position: absolute;
				left: 50%;
				top: 8px;
				width: 10px;
				height: 76px;
				transform: translateX(-50%);
				border-radius: 999px;
				background: linear-gradient(180deg, #c8d8e6, #9eb5c9);
			}
			.child {
				position: absolute;
				bottom: 19%;
				width: 56px;
				height: 106px;
			}
			.child::before {
				content: "";
				position: absolute;
				top: 0;
				left: 50%;
				width: 22px;
				height: 22px;
				transform: translateX(-50%);
				border-radius: 50%;
				background: linear-gradient(180deg, #f6d7b0, #e7b98d);
			}
			.child::after {
				content: "";
				position: absolute;
				left: 50%;
				top: 22px;
				width: 34px;
				height: 50px;
				transform: translateX(-50%);
				border-radius: 18px 18px 14px 14px;
				background: linear-gradient(180deg, #49b88f, #1e8f68);
			}
			.child-left {
				left: 22%;
			}
			.child-right {
				right: 22%;
			}
			.child-right::after {
				background: linear-gradient(180deg, #ffd967, #f4a640);
			}
			.child-arm {
				position: absolute;
				top: 35px;
				width: 38px;
				height: 10px;
				border-radius: 999px;
				background: linear-gradient(180deg, #f3d1a8, #e6b88a);
			}
			.child-left .child-arm {
				left: 24px;
				transform: rotate(-24deg);
				transform-origin: left center;
			}
			.child-right .child-arm {
				right: 24px;
				transform: rotate(24deg);
				transform-origin: right center;
			}
			.child-leg {
				position: absolute;
				top: 68px;
				width: 10px;
				height: 34px;
				border-radius: 999px;
				background: linear-gradient(180deg, #3f6990, #294d6f);
			}
			.child-left .leg-one {
				left: 20px;
				transform: rotate(8deg);
			}
			.child-left .leg-two {
				right: 20px;
				transform: rotate(-10deg);
			}
			.child-right .leg-one {
				left: 20px;
				transform: rotate(10deg);
			}
			.child-right .leg-two {
				right: 20px;
				transform: rotate(-8deg);
			}
			.mission-title {
				margin: 0 0 0.5rem 0;
				font-size: 1.9rem;
			}
			.mission-lead {
				margin: 0 0 0.7rem 0;
			}
			.mission-points {
				margin: 0;
				padding-left: 1.15rem;
				display: grid;
				gap: 0.35rem;
			}
			.mission-cta {
				margin: 0.8rem 0 0 0;
				font-weight: 700;
			}
			.calendar-wrap {
				margin-top: 2rem;
				padding: 1rem;
				border-radius: 16px;
				background:
					linear-gradient(180deg, rgba(255, 255, 255, 0.76), rgba(255, 255, 255, 0.26) 65%),
					linear-gradient(150deg, #f7fcff, #e6f5ff 50%, #e8f8f1);
				box-shadow: 0 8px 20px rgba(78, 126, 170, 0.15);
				border: 1px solid rgba(130, 192, 223, 0.35);
			}
			.calendar-title {
				margin: 0 0 0.4rem 0;
				font-size: 2rem;
			}
			.calendar-subtitle {
				margin: 0 0 0.8rem 0;
				color: rgb(var(--gray-dark));
			}
			.calendar-grid {
				display: grid;
				grid-template-columns: repeat(7, minmax(0, 1fr));
				gap: 0.45rem;
				padding: 0;
				margin: 0;
				list-style: none;
			}
			.day-card {
				border-radius: 10px;
				padding: 0.5rem;
				background:
					linear-gradient(180deg, rgba(255, 255, 255, 0.9), rgba(239, 248, 255, 0.86)),
					#ffffff;
				border: 1px solid rgba(var(--gray), 0.25);
				min-height: 7.6rem;
				display: grid;
				grid-template-rows: auto 1fr;
				gap: 0.35rem;
				box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.75);
			}
			.day-card.outside-range {
				opacity: 0.58;
				background:
					linear-gradient(180deg, rgba(255, 255, 255, 0.78), rgba(238, 241, 245, 0.84)),
					#ffffff;
			}
			.day-card.today {
				border-color: #00966e;
				box-shadow: inset 0 0 0 1px rgba(0, 150, 110, 0.28);
			}
			.weekday-row {
				display: grid;
				grid-template-columns: repeat(7, minmax(0, 1fr));
				gap: 0.45rem;
				margin: 0 0 0.45rem 0;
			}
			.weekday-cell {
				padding: 0.32rem 0.18rem;
				text-align: center;
				font-size: 0.76rem;
				font-weight: 700;
				letter-spacing: 0.03em;
				text-transform: uppercase;
				color: rgb(var(--gray-dark));
			}
			.day-heading {
				margin: 0;
				display: flex;
				align-items: center;
				gap: 0.28rem;
				font-size: 0.8rem;
				line-height: 1;
				color: rgb(var(--gray-dark));
			}
			.day-num {
				font-size: 1.25rem;
				font-weight: 700;
				color: rgb(var(--black));
			}
			.event-list {
				list-style: none;
				padding: 0;
				margin: 0;
				display: grid;
				gap: 0.25rem;
				align-content: start;
			}
			.event-item {
				padding: 0.28rem 0.35rem;
				border-radius: 6px;
				background: linear-gradient(180deg, rgba(255, 255, 255, 0.75), rgba(216, 240, 251, 0.52));
			}
			.event-title {
				margin: 0;
				font-size: 0.8rem;
				font-weight: 700;
				line-height: 1.2;
			}
			.event-meta {
				margin: 0.12rem 0 0 0;
				font-size: 0.72rem;
				color: rgb(var(--gray-dark));
			}
			.more-events {
				margin: 0.12rem 0 0 0;
				font-size: 0.72rem;
				font-weight: 700;
				color: #00966e;
			}
			.no-events {
				margin: 0;
				font-size: 0.76rem;
				color: rgb(var(--gray));
			}
			@media (max-width: 1300px) {
				.weekday-row,
				.calendar-grid {
					grid-template-columns: repeat(7, minmax(0, 1fr));
				}
			}
			@media (max-width: 900px) {
				.weekday-row,
				.calendar-grid {
					grid-template-columns: repeat(7, minmax(0, 1fr));
				}
				.weekday-cell {
					font-size: 0.68rem;
				}
			}
			@media (max-width: 700px) {
				.mission-wrap {
					padding: 1.15rem 1rem;
				}
				.mission-layout {
					grid-template-columns: 1fr;
				}
				.mission-visual {
					width: min(100%, 360px);
					justify-self: center;
				}
				.weekday-row,
				.calendar-grid {
					grid-template-columns: repeat(7, minmax(0, 1fr));
				}
				.weekday-cell {
					font-size: 0.58rem;
					padding: 0.22rem 0.08rem;
				}
				.day-card {
					min-height: 5.1rem;
					padding: 0.28rem;
				}
				.day-heading {
					font-size: 0.56rem;
					gap: 0.16rem;
				}
				.day-num {
					font-size: 0.82rem;
				}
				.event-title {
					font-size: 0.54rem;
					line-height: 1.1;
				}
				.event-meta,
				.more-events,
				.no-events {
					font-size: 0.48rem;
				}
			}
			@media (max-width: 480px) {
				.weekday-row,
				.calendar-grid {
					grid-template-columns: repeat(7, minmax(0, 1fr));
					gap: 0.35rem;
				}
				.weekday-cell {
					font-size: 0.5rem;
					letter-spacing: 0.01em;
				}
				.day-card {
					min-height: 4.55rem;
					padding: 0.2rem;
				}
				.day-heading {
					font-size: 0.46rem;
					gap: 0.12rem;
				}
				.day-num {
					font-size: 0.7rem;
				}
				.event-title {
					font-size: 0.48rem;
				}
				.event-meta,
				.more-events,
				.no-events {
					font-size: 0.42rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="mission-wrap">
				<div class="mission-layout">
					<div>
						<h1 class="mission-title"><span data-i18n-bg="Нашата Мисия" data-i18n-en="Our Mission">Нашата Мисия</span></h1>
						<p class="mission-lead">
							<span
								data-i18n-bg="Изграждаме общност от информирани, активни и интелигентни младежи от цяла България, с фокус върху младите хора в малките населени места."
								data-i18n-en="We build a community of informed, active, and intelligent youth across Bulgaria, with a focus on young people in smaller towns and villages."
							>
								Изграждаме общност от информирани, активни и интелигентни младежи от цяла България, с фокус
								върху младите хора в малките населени места.
							</span>
						</p>
						<ul class="mission-points">
							<li><span data-i18n-bg="Кариерна и професионална ориентация чрез съвременни образователни методики." data-i18n-en="Career and professional orientation through modern educational methods.">Кариерна и професионална ориентация чрез съвременни образователни методики.</span></li>
							<li><span data-i18n-bg="Развитие на заложби в науки, изкуства и професии." data-i18n-en="Development of talent in sciences, arts, and professions.">Развитие на заложби в науки, изкуства и професии.</span></li>
							<li>
								<span
									data-i18n-bg="Практическо запознаване с теми като гражданско образование, икономика, политика, финансова грамотност, екология и медии."
									data-i18n-en="Practical introduction to civic education, economics, politics, financial literacy, ecology, and media."
								>
									Практическо запознаване с теми като гражданско образование, икономика, политика, финансова
									грамотност, екология и медии.
								</span>
							</li>
							<li><span data-i18n-bg="Подкрепа на местната култура, изкуства и традиции." data-i18n-en="Support for local culture, arts, and traditions.">Подкрепа на местната култура, изкуства и традиции.</span></li>
							<li><span data-i18n-bg="Личностно израстване, творческа изява и активна обществена комуникация." data-i18n-en="Personal growth, creative expression, and active social communication.">Личностно израстване, творческа изява и активна обществена комуникация.</span></li>
						</ul>
						<p class="mission-cta">
							<span data-i18n-bg="Пълният текст на целите можете да прочетете на страницата " data-i18n-en="You can read the full mission details on the page ">Пълният текст на целите можете да прочетете на страницата </span><a href="/about"><span data-i18n-bg="„За нас“" data-i18n-en="“About us”">„За нас“</span></a>.
						</p>
					</div>
					<div class="mission-visual" aria-hidden="true">
						<div class="sun"></div>
						<div class="cloud cloud-one"></div>
						<div class="cloud cloud-two"></div>
						<div class="bird bird-one"></div>
						<div class="bird bird-two"></div>
						<div class="book">
							<div class="book-left"></div>
							<div class="book-right"></div>
							<div class="book-spine"></div>
						</div>
						<div class="child child-left">
							<div class="child-arm"></div>
							<div class="child-leg leg-one"></div>
							<div class="child-leg leg-two"></div>
						</div>
						<div class="child child-right">
							<div class="child-arm"></div>
							<div class="child-leg leg-one"></div>
							<div class="child-leg leg-two"></div>
						</div>
					</div>
				</div>
			</section>
			<section class="calendar-wrap">
				<h2 class="calendar-title"><span data-i18n-bg="Календар: Следващи 31 Дни" data-i18n-en="Calendar: Next 31 Days">Календар: Следващи 31 Дни</span></h2>
				<p class="calendar-subtitle">
					<span data-i18n-bg="Показва всички събития от днес нататък за 31 дни напред." data-i18n-en="Shows all events from today through the next 31 days.">Показва всички събития от днес нататък за 31 дни напред.</span>
				</p>
				<div class="weekday-row" aria-hidden="true">
					{
						weekdayHeaders.map((day) => (
							<div class="weekday-cell">
								<span data-i18n-bg={day.bg} data-i18n-en={day.en}>{day.bg}</span>
							</div>
						))
					}
				</div>
				<ul class="calendar-grid">
					{
						calendarCells.map((day) => (
							<li class:list={['day-card', { today: day.isToday, 'outside-range': !day.isCurrentRange }]}>
								<h3 class="day-heading" title={day.fullLabel}>
									<span class="day-num">{day.dayNumber}</span>
									<span data-i18n-bg={day.weekLabelBg} data-i18n-en={day.weekLabelEn}>
										{day.weekLabelBg}
									</span>
									<span data-i18n-bg={day.monthLabelBg} data-i18n-en={day.monthLabelEn}>
										{day.monthLabelBg}
									</span>
								</h3>
								{day.items.length === 0 ? (
									<p class="no-events" data-i18n-bg="Няма събития" data-i18n-en="No events">Няма събития</p>
								) : (
									<ul class="event-list">
										{day.items.slice(0, 2).map((item) => (
											<li class="event-item">
												<p class="event-title">{item.data.title}</p>
												{(item.data.time || item.data.location) && (
													<p class="event-meta">
														{item.data.time && <span>{item.data.time}</span>}
														{item.data.time && item.data.location && <span> · </span>}
														{item.data.location && <span>{item.data.location}</span>}
													</p>
												)}
											</li>
										))}
										{day.items.length > 2 && (
											<li
												class="more-events"
												data-i18n-template-bg="+{n} още"
												data-i18n-template-en="+{n} more"
												data-i18n-count={String(day.items.length - 2)}
											>
												+{day.items.length - 2} още
											</li>
										)}
									</ul>
								)}
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
